# Local credentials. Copy to `.env`, fill in real values, then `source .env`
# before running pipeline scripts. NEVER commit `.env` (already gitignored).

# GitHub Personal Access Token — no special scopes needed for public-data
# search. Generate at https://github.com/settings/tokens
export GITHUB_TOKEN=ghp_your_token_here

# ORCID public-API client. Register at https://orcid.org/developer-tools
export ORCID_CLIENT_ID=APP-XXXXXXXXXXXXXXXX
export ORCID_CLIENT_SECRET=00000000-0000-0000-0000-000000000000
