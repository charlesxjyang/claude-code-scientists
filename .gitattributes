# Git LFS — large data and figure binaries
data/*.json   filter=lfs diff=lfs merge=lfs -text
data/*.txt    filter=lfs diff=lfs merge=lfs -text
figures/*.png filter=lfs diff=lfs merge=lfs -text
figures/*.svg filter=lfs diff=lfs merge=lfs -text
# Normalize text line endings
*.py    text eol=lf
*.md    text eol=lf
*.sh    text eol=lf
